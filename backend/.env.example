# ── Visum Backend Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit secrets to version control.

# Database — Optional. If omitted, runs without persistence.
# PostgreSQL connection string (Render, Supabase, Neon, etc.)
DATABASE_URL=

# CORS — Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://visum-eight.vercel.app

# Concurrency — Tune scan throughput
MAX_CONCURRENT_SCANS=5
SCAN_SEMAPHORE_WAIT_SECONDS=30

# Cache — Scan result memory cache
MAX_SCAN_CACHE_SIZE=1000
SCAN_CACHE_TTL_SECONDS=3600

# Crawler — Timeout per crawl operation (milliseconds)
CRAWLER_TIMEOUT_MS=60000

# Rate Limiting — Max scans per IP per hour
RATE_LIMIT_SCANS_PER_HOUR=30

# Global Scan Timeout — Max total seconds for a scan (crawl + scoring)
# If exceeded, the scan is cancelled and returns 408
SCAN_TIMEOUT_SECONDS=45

# NOTE: All variables are optional. Every one has a sensible default.
# The app gracefully degrades if any are missing.
