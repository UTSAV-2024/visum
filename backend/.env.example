# backend/.env.example - safe to commit
# Copy this file to .env and fill in your values

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,https://visum-eight.vercel.app

# -- PostgreSQL (Optional) --
# Leave EMPTY to run without a database. The app gracefully degrades.
# WARNING: Do NOT use placeholder values like 'user:password' or 'hostname' --
# these will crash SQLAlchemy on startup.
# Set a real Supabase/Neon/Cloud SQL connection string, or leave blank.
# Example:
# DATABASE_URL=postgresql://postgres:your_real_password@db.example.supabase.co:5432/postgres
DATABASE_URL=

# -- Crawler Settings --
CRAWLER_TIMEOUT_MS=30000
MAX_CONCURRENT_SCANS=5
SCAN_CACHE_TTL_SECONDS=3600
