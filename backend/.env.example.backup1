# backend/.env.example - safe to commit
# Copy this file to .env and fill in your values

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,https://visum-eight.vercel.app

# PostgreSQL connection string (set on Render, not in .env)
# Leave empty to run without database
DATABASE_URL=postgresql://user:password@hostname:5432/database

# Crawler settings
CRAWLER_TIMEOUT_MS=30000
MAX_CONCURRENT_SCANS=5
SCAN_CACHE_TTL_SECONDS=3600
